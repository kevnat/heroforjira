# ── Jira (required) ──────────────────────────────────────────────────────────
# These stay server-side (no VITE_ prefix) — never sent to the browser.
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your_api_token_here
JIRA_SITE=https://yourorg.atlassian.net

# ── Jira display (required) ───────────────────────────────────────────────────
# Read by the frontend to label cards and build Jira links.
VITE_JIRA_PROJECT=My Team Project
VITE_JIRA_SITE=https://yourorg.atlassian.net

# ── Passphrase lock (required) ────────────────────────────────────────────────
# SHA-256 hex of your edit passphrase. Generate with:
#   echo -n "yourpassword" | shasum -a 256
VITE_EDIT_PASSPHRASE_HASH=

# ── Supabase (optional) ───────────────────────────────────────────────────────
# Enables shared board state across teammates. Without these, state saves to
# the browser only (localStorage). See README for setup steps.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
